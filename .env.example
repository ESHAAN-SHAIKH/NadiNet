# ════════════════════════════════════════════════════════════════
# NadiNet — .env.example
# Copy to .env and fill in the values you need.
# ════════════════════════════════════════════════════════════════
#
# LOCAL / OFFLINE MODE (no external APIs):
#   Leave GOOGLE_API_KEY, TWILIO_*, and GOOGLE_CLOUD_PROJECT blank.
#   - NLP: built-in keyword classifier (English + Hinglish, ~75-80% accuracy)
#   - OCR: pytesseract (runs locally)
#   - WhatsApp: messages printed to terminal instead of sent
#   Only docker + PostgreSQL are required.
#
# PRODUCTION MODE: fill in all values below.
# ════════════════════════════════════════════════════════════════

# ── Database (required) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nadinet:nadinet@db:5432/nadinet

# ── Twilio WhatsApp (optional — blank = console mock) ────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Google AI (optional — blank = local keyword classifier) ──────
# Gemini 1.5-flash for NLP classification, text-embedding-004 for few-shot
GOOGLE_API_KEY=

# ── Google Cloud Vision OCR (optional — blank = pytesseract) ─────
GOOGLE_CLOUD_PROJECT=

# ── JWT Authentication (required — change before production) ─────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── NLP few-shot examples path ───────────────────────────────────
FEW_SHOT_EXAMPLES_PATH=./models/few_shot_examples.json

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Scheduler ─────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC

# ── Reporting ─────────────────────────────────────────────────────
NGO_NAME=NadiNet NGO
